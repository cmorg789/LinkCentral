# Server Configuration
HOST=0.0.0.0
PORT=8000
SOAP_PATH=/ScriptLinkService.asmx

# Database (request logging)
DATABASE_URL=sqlite:///data/scriptlink.db

# Security - Only required if using password_encrypted in connections.yaml (recommended)
# Generate a key (minimum 32 characters): python -c "import secrets; print(secrets.token_urlsafe(32))"
# SECRET_KEY=

# Script Execution
SCRIPT_TIMEOUT=30              # Maximum script execution time in seconds
SCRIPT_ERROR_BLOCKING=False    # True = unhandled errors block form, False = show as alert

# Debugging
DEBUG=False                    # Enable verbose logging
