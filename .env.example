# Server Configuration
HOST=0.0.0.0
PORT=8000
SOAP_PATH=/ScriptLinkService.asmx
# SOAP service name in WSDL
SERVICE_NAME=LinkCentral

# Database (request logging)
DATABASE_URL=sqlite:///data/scriptlink.db

# Script Execution
# Maximum script execution time in seconds. Note: a timed-out script's thread
# keeps running in the background until it returns; the timeout only releases
# the waiting request.
SCRIPT_TIMEOUT=30
# Max concurrently running scripts
SCRIPT_MAX_CONCURRENCY=16
# Max requests waiting for a worker before rejecting with an overload ALERT
SCRIPT_MAX_QUEUED=32
# True = unhandled errors block form, False = show as alert
SCRIPT_ERROR_BLOCKING=False

# Log full request/response bodies in request_log table
# WARNING: This captures PHI (field values, patient IDs)
LOG_REQUEST_BODY=False

# How often to prune old request logs (minutes) (0 = disabled)
CLEANUP_INTERVAL_MINUTES=0
# Delete logs older than this many days
CLEANUP_RETENTION_DAYS=30

# Debugging - Enable verbose logging
DEBUG=False
